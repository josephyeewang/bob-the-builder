.DS_Store
*.swp
*~

# ── SECRETS (standard template) ──
# Never commit real secrets. Put them in .env.local (which is gitignored below).
.env
.env.local
.env.*.local
!.env.example

# ── DEPS / BUILD ──
node_modules/
dist/
build/
.next/
.vercel/

# ── LOGS ──
*.log
npm-debug.log*

# ── EDITORS ──
.vscode/
.idea/
*.swp

# ── CLAUDE CODE LOCAL STATE ──
.claude/worktrees/
.claude/scheduled_tasks.lock

# ── LENS RETROS (private-by-default) ──
# Raw audit retros cite project-specific findings, schema details, and commit
# hashes. This is a PUBLIC repo — never commit raw retros. The collection point
# (README + .gitkeep) is tracked; the data is not. scripts/lens-retro.sh reads
# them locally. Only sanitized, genericized change-requests go upstream.
# See audit-lenses/_lens-retro.md §B.
lens-retros/*.json
!lens-retros/.gitkeep
